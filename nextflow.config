/*
 * ProteomicsDA Pipeline Configuration
 */

// ============================================================
// Default parameters
// ============================================================
params {

    // --- Required (set via --param on command line or in a params file) ---
    data_url        = null
    sample_sheet    = null
    condition_a     = null
    condition_b     = null

    // --- Optional with sensible defaults ---
    min_valid_values = 2        // min samples with valid intensity per protein
    fdr_cutoff       = 0.05     // BH-adjusted p-value cutoff
    fc_cutoff        = 1.0      // log2 fold change cutoff for volcano plot
    outdir           = "results"
}

// ============================================================
// Process resource labels
// ============================================================
process {
    withLabel: 'process_low' {
        cpus   = 2
        memory = '4 GB'
        time   = '30 min'
    }
}

// ============================================================
// Execution profiles
// ============================================================
profiles {

    // --- Local: uses Docker (default for demo/laptop) ---
    docker {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process.container = 'shaunak/proteomicsda:1.0'
    }

    // --- Local: uses Conda (alternative if Docker not available) ---
    conda {
        conda.enabled = true
        process.conda = "${projectDir}/environment.yml"
    }


    // --- Test profile: uses bundled test data ---
    test {
        params.data_url = "https://raw.githubusercontent.com/statOmics/PDA21/data/quantification/cptacAvsB_lab3/proteinGroups.txt"
        params.sample_sheet     = "${projectDir}/test-data/test_sample_sheet.csv"
        params.condition_a      = "6A"
        params.condition_b      = "6B"
        params.min_valid_values = 2
        params.fdr_cutoff       = 0.05
        params.fc_cutoff        = 1.0
        params.outdir           = "test_results"
    }
}

// ============================================================
// Reporting
// ============================================================
report {
    enabled   = true
    file      = "${params.outdir}/pipeline_report.html"
    overwrite = true
}

timeline {
    enabled   = true
    file      = "${params.outdir}/timeline.html"
    overwrite = true
}

dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_dag.html"
    overwrite = true
}

// ============================================================
// Manifest
// ============================================================
manifest {
    name        = 'ProteomicsDA'
    description = 'Reproducible proteomics differential abundance analysis pipeline'
    version     = '1.0.0'
    author      = 'Shaunak Raole'
    nextflowVersion = '>=23.04.0'
}
