/*
 * RAPID Pipeline Configuration
 * Reproducible Analysis Pipeline for Intensity-based proteomics Data
 */

// ============================================================
// Default parameters
// ============================================================
params {
    // --- Required ---
    data_url = null
    sample_sheet = null

    // --- Optional: only needed for single-comparison mode (legacy) ---
    condition_a = null
    condition_b = null

    // --- Analysis defaults ---
    min_valid_values = 2
    fdr_cutoff = 0.05
    fc_cutoff = 1.0
    outdir = "results"

    // --- Organism for pathway enrichment ---
    // Options: human, mouse, rat, yeast
    organism = "human"
}

// ============================================================
// Process resource labels
// ============================================================
process {
    withLabel: 'process_low' {
        cpus = 2
        memory = '4 GB'
        time = '30 min'
    }
}

// ============================================================
// Execution profiles
// ============================================================
profiles {

    // Docker (reproducibility!)
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process.container = 'shaunakr/rapid:1.0'
    }

    // Conda (local development)
    conda {
        conda.enabled = true
        process.conda = "${projectDir}/environment.yml"
    }

    // Test profile (uses verified CPTAC benchmark dataset)
    // 6 samples, 2 conditions (6A vs 6B)
    test {
        params.data_url = "https://raw.githubusercontent.com/statOmics/PDA21/data/quantification/cptacAvsB_lab3/proteinGroups.txt"
        params.sample_sheet = "${projectDir}/test-data/test_sample_sheet.csv"
        params.condition_a = "6A"
        params.condition_b = "6B"
        params.min_valid_values = 2
        params.fdr_cutoff = 0.05
        params.fc_cutoff = 1.0
        params.outdir = "test_results"
    }
}

// ============================================================
// Nextflow reporting
// ============================================================
report {
    enabled = true
    file = "${params.outdir}/pipeline_report.html"
    overwrite = true
}

timeline {
    enabled = true
    file = "${params.outdir}/timeline.html"
    overwrite = true
}

dag {
    enabled = true
    file = "${params.outdir}/pipeline_dag.html"
    overwrite = true
}

// ============================================================
// Manifest
// ============================================================
manifest {
    name = 'RAPID'
    description = 'Reproducible Analysis Pipeline for Intensity-based proteomics Data'
    version = '1.0.0'
    author = 'Shaunak Raole'
    nextflowVersion = '>=23.04.0'
}
